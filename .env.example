# Vorlage für Umgebungsvariablen.
# Kopiere diese Datei zu `.env` und trag echte Werte ein.
# `.env` steht in .gitignore und wird NIE committet.

# Anthropic API
ANTHROPIC_API_KEY=

# Modell für die Extraktion (Default, wenn leer: claude-haiku-4-5-20251001)
ANTHROPIC_MODEL=

# Confidence-Schwelle für needs_review (Default, wenn leer: 0.8)
CONFIDENCE_THRESHOLD=

# Konditionen-Block im Antwort-Entwurf rendern (true/false, Default: false)
DRAFT_INCLUDE_CONDITIONS=
